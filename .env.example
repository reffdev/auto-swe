# Server
PORT=3001
DB_PATH=./open-swe.db
PROJECTS_BASE=./.projects
WORKTREE_BASE=./.worktrees
SERVICE_NAME=swe
SWE_RETENTION_DAYS=30

# Sandbox (Linux + bubblewrap only)
SWE_SANDBOX_CACHE_ROOT=~/.swe-cache

# LLM warmup tuning (ms)
SWE_WARMUP_BUDGET_MS=300000
SWE_WARMUP_ATTEMPT_TIMEOUT_MS=300000
SWE_WARMUP_BACKOFF_INITIAL_MS=2000

# LLM debug dumps (optional)
# LLM_DEBUG_DUMP_DIR=./.llm-dumps
# LLM_DEBUG_DUMP_DISABLE=1

# Library docs lookup (optional)
# CONTEXT7_API_KEY=

# Voice pipeline (all optional — omit to disable voice features)
# STT_URL=http://localhost:8080
# VOICE_LLM_URL=http://localhost:8081
# VOICE_MODEL_ID=default
# VOICE_SYSTEM_PROMPT=
# TTS_URL=http://localhost:8082
# PIPER_URL=http://localhost:5000
# PIPER_PATH=/usr/local/bin/piper
# PIPER_MODEL=/path/to/voice.onnx
# PIPER_CONFIG=/path/to/voice.onnx.json
